{
  "expo": {
    "name": "Fyneex Organizador",
    "slug": "fyneex-operador",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#111111",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fyneex.operador",
      "infoPlist": {
        "NSCameraUsageDescription": "Este app precisa da câmera para ler os QR codes dos participantes no check-in."
      }
    },
    "android": {
      "package": "com.fyneex.operador",
      "versionCode": 1,
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Este app precisa da câmera para ler os QR codes dos participantes no check-in.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "usesCleartextTraffic": false,
            "networkSecurityConfig": "./network_security_config.xml",
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.fyneex.operador.** { *; }\n-dontwarn org.conscrypt.**\n-dontwarn com.facebook.react.**\n-keep class com.facebook.hermes.** { *; }\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.swmansion.worklets.** { *; }\n-keep class expo.modules.** { *; }\n-keep class expo.modules.securestore.** { *; }\n-dontwarn expo.modules.**"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/a0f2ec89-ed24-468b-b5df-43ee1e82066e"
    },
    "extra": {
      "eas": {
        "projectId": "a0f2ec89-ed24-468b-b5df-43ee1e82066e"
      }
    },
    "owner": "zuuny"
  }
}
